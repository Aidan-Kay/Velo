{
  "name": "vinted-manager",
  "version": "1.0.0",
  "description": "Vinted Manager — account management tool for Vinted sellers",
  "main": "./out/main/main.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && npx electron-builder --win --publish never",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "lucide-react": "^0.577.0",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.vintedmanager.app",
    "productName": "VintedManager",
    "files": [
      "out/**/*",
      "!**/.vscode/*",
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{tsconfig.json,tsconfig.*.json}",
      "!{.env,.env.*,.npmrc}"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    }
  }
}
